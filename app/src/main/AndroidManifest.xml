<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".MainApp"
        android:allowBackup="true"
        android:icon="@mipmap/logo_new"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/logo_new"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:requestLegacyExternalStorage="true"
        tools:replace="android:icon,android:roundIcon,android:theme">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.fuusy.project.ui.activity.ProjectDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/AppTheme.NoActionBar" />
        <activity
            android:name="com.fuusy.hiddendanger.ui.CreateWorkOrderActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar"
            tools:replace="android:theme"/>


        <activity
            android:name="com.fuusy.project.ui.activity.HistoryOrderActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar"
            tools:replace="android:theme" />

        <activity
            android:name="com.fuusy.project.ui.activity.CloudControlActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar"
            tools:replace="android:theme" />

        <activity
            android:name="com.fuusy.project.ui.activity.VideoFullScreenActivity"
            android:exported="false"
            android:screenOrientation="sensorLandscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/AppTheme.NoActionBar"
            tools:replace="android:theme" />

        <activity
            android:name="com.fuusy.project.ui.activity.UwbDebugActivity"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBar"
            tools:replace="android:theme" />

        <activity android:name="com.fuusy.jetpackkt.MainActivity" />

    </application>


</manifest>