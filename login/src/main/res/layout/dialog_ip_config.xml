<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="服务器配置"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="使用本地服务器"
            android:textSize="15sp"
            android:textColor="#333333" />

        <Switch
            android:id="@+id/sw_use_local"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_active_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="当前生效："
        android:textSize="13sp"
        android:textColor="#E65100"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:id="@+id/layout_local"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="电脑局域网 IP（手机和电脑同一 WiFi）"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/et_local_ip"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="2"
                android:hint="如 192.168.1.100"
                android:padding="8dp"
                android:background="@drawable/bg_edit_text"
                android:layout_marginEnd="8dp"
                android:inputType="text" />

            <EditText
                android:id="@+id/et_local_port"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="端口"
                android:padding="8dp"
                android:background="@drawable/bg_edit_text"
                android:inputType="number" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="本地模式下，登录/工单/OKR 均走此地址"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="16dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_remote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="远程测试服（默认）"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="主服务器：8.130.120.35:9220\n工单/OKR服务器：https://ios.yceil.com"
            android:textSize="13sp"
            android:textColor="#999999"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="取消"
            android:textColor="#666666"
            android:background="@drawable/bg_button_outline"
            android:backgroundTint="@null"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="保存"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@null"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
