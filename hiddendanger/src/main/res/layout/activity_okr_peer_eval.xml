<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/personal_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:minHeight="48dp"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:contentDescription="@null"
                android:padding="8dp"
                android:src="@drawable/ic_back_black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="360 互评"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tab_review"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_goal_period_tab_selected"
                android:gravity="center"
                android:text="Q2 复盘"
                android:textColor="#1365EC"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tab_eval"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_goal_period_tab_normal"
                android:gravity="center"
                android:text="待我评价"
                android:textColor="#686D79"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tab_received"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/bg_goal_period_tab_normal"
                android:gravity="center"
                android:text="收到的评价"
                android:textColor="#686D79"
                android:textSize="12sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/panel_review"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 卡片 1：标题 / 说明 -->
                    <LinearLayout
                        android:id="@+id/card_review_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_personal_menu_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_review_section_title"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Q2 产出与收获"
                                android:textColor="#000000"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_review_saved_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_goal_status_processing"
                                android:gravity="center"
                                android:paddingHorizontal="8dp"
                                android:text="已提交"
                                android:textColor="#00AA60"
                                android:textSize="11sp"
                                android:visibility="gone"
                                tools:visibility="visible" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_review_period_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="#686D79"
                            android:textSize="12sp"
                            android:visibility="gone"
                            tools:text="Q2 2026 复盘记录"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/tv_review_section_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="周会话题 1：填写本季度项目产出与技能成长，并选择合作同事"
                            android:textColor="#686D79"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_peer_eval_scope"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="#A7AFC3"
                            android:textSize="11sp"
                            tools:text="基于 Q2 2026 合作经历进行互评" />
                    </LinearLayout>

                    <!-- 卡片 2：项目 / 产出 -->
                    <LinearLayout
                        android:id="@+id/card_review_project"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_personal_menu_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="项目 / 产出"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_project_output"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_goal_input"
                            android:gravity="top"
                            android:hint="本季度完成的项目、交付成果…"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minHeight="88dp"
                            android:padding="10dp"
                            android:textColor="#000000"
                            android:textColorHint="#A7AFC3"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_project_output"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_goal_input"
                            android:lineSpacingExtra="4dp"
                            android:padding="10dp"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:visibility="gone"
                            tools:text="测试123456"
                            tools:visibility="visible" />
                    </LinearLayout>

                    <!-- 卡片 3：技能 / 成长 -->
                    <LinearLayout
                        android:id="@+id/card_review_skill"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_personal_menu_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="技能 / 成长"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/et_skill_growth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_goal_input"
                            android:gravity="top"
                            android:hint="技能提升、经验收获…"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minHeight="72dp"
                            android:padding="10dp"
                            android:textColor="#000000"
                            android:textColorHint="#A7AFC3"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_skill_growth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_goal_input"
                            android:lineSpacingExtra="4dp"
                            android:padding="10dp"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:visibility="gone"
                            tools:text="测试123456"
                            tools:visibility="visible" />
                    </LinearLayout>

                    <!-- 卡片 4：合作同事 -->
                    <LinearLayout
                        android:id="@+id/card_review_collaborators"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_personal_menu_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="合作同事"
                                android:textColor="#000000"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btn_add_collaborator"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingVertical="4dp"
                                android:text="+ 添加"
                                android:textColor="#1365EC"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_collaborator_hint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="基于 Q2 合作经历选择，将作为 360 环评对象"
                            android:textColor="#A7AFC3"
                            android:textSize="11sp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_collaborators"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            tools:itemCount="2"
                            tools:listitem="@layout/item_peer_collaborator" />

                        <TextView
                            android:id="@+id/tv_no_collaborator"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="16dp"
                            android:text="暂未添加合作同事"
                            android:textColor="#A7AFC3"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:visibility="visible" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btn_save_review"
                        style="@style/AppButton.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:text="保存复盘"
                        android:textSize="15sp" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <FrameLayout
                android:id="@+id/panel_eval"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_tasks"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    tools:listitem="@layout/item_peer_eval_task" />

                <TextView
                    android:id="@+id/tv_tasks_empty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:text="暂无需要您评价的同事。若您已保存复盘并选择合作同事，请等待对方评价您，结果将汇总在「收到的评价」"
                    android:textColor="#A7AFC3"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </FrameLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/panel_received"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_personal_menu_card"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="同事对我的评价"
                        android:textColor="#000000"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="匿名汇总，不展示具体评价人"
                        android:textColor="#686D79"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_received_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="#686D79"
                        android:textSize="13sp"
                        tools:text="5 位同事已完成评价" />

                    <TextView
                        android:id="@+id/tv_received_score"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#1365EC"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        tools:text="4.3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="综合平均分"
                        android:textColor="#686D79"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/btn_view_received_detail"
                        style="@style/AppButton.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="查看评价详情"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tv_received_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:paddingVertical="24dp"
                        android:text="暂无同事评价，互评结束后将在此汇总展示"
                        android:textColor="#A7AFC3"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
