<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/personal_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="88dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero -->
            <LinearLayout
                android:id="@+id/hero_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_goal_form_hero"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:id="@+id/btn_back"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_goal_form_period_normal"
                        android:contentDescription="@null"
                        android:padding="8dp"
                        android:src="@drawable/ic_back_black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="添加目标"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="8dp"
                    android:text="目标周期"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tab_q2"
                            android:layout_width="wrap_content"
                            android:layout_height="29dp"
                            android:background="@drawable/bg_goal_form_period_selected"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="Q2 2026"
                            android:textColor="#1365EC"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tab_q3"
                            android:layout_width="wrap_content"
                            android:layout_height="29dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_goal_form_period_normal"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="Q3 2026"
                            android:textColor="#000000"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tab_q4"
                            android:layout_width="wrap_content"
                            android:layout_height="29dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_goal_form_period_normal"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="Q4 2026"
                            android:textColor="#000000"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tab_annual"
                            android:layout_width="wrap_content"
                            android:layout_height="29dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_goal_form_period_normal"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="年度目标"
                            android:textColor="#000000"
                            android:textSize="12sp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 目标 O -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_goal_form_card"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_goal_o_badge"
                        android:gravity="center"
                        android:text="O"
                        android:textColor="#1365EC"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="目标 (Objective)"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="目标内容"
                    android:textColor="#686D79"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_objective"
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_goal_input"
                    android:gravity="top|start"
                    android:hint="请输入你的目标，例如：提升产品质量与交付效率"
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textColor="#000000"
                    android:textColorHint="#80686D79"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="目标说明（选填）"
                    android:textColor="#686D79"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="66dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_goal_input"
                    android:gravity="top|start"
                    android:hint="补充说明目标的背景、意义或衡量标准…"
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textColor="#000000"
                    android:textColorHint="#80686D79"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 所属部门 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_goal_form_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="所属部门"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="目标归属部门 *"
                    android:textColor="#686D79"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/row_own_dept"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_goal_input"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                        <TextView
                            android:id="@+id/tv_own_dept"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            tools:text="华东区" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_dropdown_arrow" />
                </LinearLayout>
            </LinearLayout>

            <!-- 对齐 OKR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_goal_form_card"
                android:orientation="vertical"
                android:padding="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="对齐上级/部门 OKR"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_align"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:checked="true"
                        app:thumbTint="#FFFFFF"
                        app:trackTint="#1365EC" />
                </RelativeLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="3dp"
                    android:text="将你的KR挂到上级或部门的目标下，形成层级对齐关系"
                    android:textColor="#686D79"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/ll_align_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginTop="12dp"
                        android:alpha="0.25"
                        android:background="#686D79" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/tab_align_dept"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_goal_align_selected"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_align_dept_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="部门目标"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="对齐部门级OKR"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/tab_align_supervisor"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_goal_align_normal"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_align_supervisor_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="上级目标"
                                android:textColor="#000000"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="对齐直属上级OKR"
                                android:textColor="#686D79"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_align_scope_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="选择部门 *"
                        android:textColor="#686D79"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/row_align_level"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_goal_input"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:id="@+id/tv_align_level"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            tools:text="软件研发部" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_dropdown_arrow" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="选择对齐的 KR *"
                        android:textColor="#686D79"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/row_align_target"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_goal_input"
                        android:gravity="center_vertical"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:id="@+id/tv_align_target"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            tools:text="提升平台稳定性与交付效率" />

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_dropdown_arrow" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_goal_align_tip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@drawable/bg_goal_o_badge"
                            android:gravity="center"
                            android:text="i"
                            android:textColor="#1365EC"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:lineSpacingExtra="3dp"
                            android:text="对齐说明：选择上级已审批通过的 KR，创建后将挂到该 KR 下形成层级对齐"
                            android:textColor="#686D79"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- KR 列表 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="26dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_goal_kr_badge"
                    android:gravity="center"
                    android:text="KR"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="关键结果 (Key Results)"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_kr_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已添加 1 条"
                    android:textColor="#686D79"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_kr_weight_total"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="4dp"
                android:text="权重合计 100%"
                android:textColor="#00AA60"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_kr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                tools:itemCount="2"
                tools:listitem="@layout/item_goal_kr_edit" />

            <LinearLayout
                android:id="@+id/btn_add_kr"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_goal_add_kr"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_goal_add" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="添加关键结果 (KR)"
                    android:textColor="#6A2DF6"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="77dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/btn_cancel"
            style="@style/AppButton.Secondary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="取消" />

        <TextView
            android:id="@+id/btn_draft"
            style="@style/AppButton.Secondary"
            android:layout_width="0dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="暂存草稿"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_submit"
            style="@style/AppButton.Primary"
            android:layout_width="0dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1.5"
            android:text="创建目标" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
