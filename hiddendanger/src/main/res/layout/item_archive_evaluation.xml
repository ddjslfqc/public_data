<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_personal_menu_card"
    android:orientation="vertical"
    android:padding="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_avatar"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_archive_avatar"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="章" />

        <TextView
            android:id="@+id/tv_reviewer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@id/tv_avatar"
            android:layout_centerVertical="true"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="章北海" />

        <TextView
            android:id="@+id/tv_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:textColor="#F5BD1D"
            android:textSize="12sp"
            tools:text="★★★★★" />
    </RelativeLayout>

    <TextView
        android:id="@+id/tv_tag"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:textSize="11sp"
        android:visibility="gone"
        tools:text="无问题，很完美"
        tools:textColor="#00AA60"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="4dp"
        android:textColor="#686D79"
        android:textSize="14sp"
        tools:text="客户门户体验优化需求完成得非常出色，响应迅速，沟通顺畅，专业能力很强！" />

    <TextView
        android:id="@+id/tv_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alpha="0.5"
        android:textColor="#686D79"
        android:textSize="12sp"
        tools:text="WD202606180001·2026-06-18" />

</LinearLayout>
