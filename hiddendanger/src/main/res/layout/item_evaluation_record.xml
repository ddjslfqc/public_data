<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_personal_menu_card"
    android:orientation="vertical"
    android:padding="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_avatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:background="@drawable/bg_archive_avatar"
            tools:text="章" />

        <TextView
            android:id="@+id/tv_reviewer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_toEndOf="@id/tv_avatar"
            android:layout_toStartOf="@id/tv_rating"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="章北海" />

        <TextView
            android:id="@+id/tv_department"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_reviewer"
            android:layout_alignStart="@id/tv_reviewer"
            android:layout_marginTop="4dp"
            android:alpha="0.6"
            android:textColor="#686D79"
            android:textSize="12sp"
            tools:text="检修部" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignBottom="@id/tv_department"
            android:alpha="0.6"
            android:textColor="#686D79"
            android:textSize="12sp"
            tools:text="2026-06-15" />

        <TextView
            android:id="@+id/tv_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/tv_reviewer"
            android:textColor="#F5BD1D"
            android:textSize="12sp"
            tools:text="★★★★★" />
    </RelativeLayout>

    <TextView
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alpha="0.7"
        android:lineSpacingExtra="4dp"
        android:textColor="#686D79"
        android:textSize="14sp"
        tools:text="处理速度很快，专业能力强，设备故障很快就解决了，非常满意！" />

    <LinearLayout
        android:id="@+id/row_work_order"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_eval_work_order_chip"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_eval_work_order" />

        <TextView
            android:id="@+id/tv_work_order"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#1465EB"
            android:textSize="14sp"
            tools:text="主控室空调滤网清洗" />
    </LinearLayout>

</LinearLayout>
