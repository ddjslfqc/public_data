<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:bottomLeftRadius="0dp" android:bottomRightRadius="14dp" android:topLeftRadius="0dp" android:topRightRadius="14dp" />
            <gradient android:angle="0" android:endColor="#ffCB2A27" android:startColor="#ffDD4E4D" android:type="linear" android:useLevel="true" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white" />
            <corners android:bottomLeftRadius="0dp" android:bottomRightRadius="14dp" android:topLeftRadius="14dp" android:topRightRadius="8dp" />
        </shape>
    </item>
</selector>