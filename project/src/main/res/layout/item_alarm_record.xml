<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:layout_marginBottom="12dp"
    android:elevation="2dp"
    android:clipToPadding="false"
    android:layout_marginLeft="8dp"
    android:layout_marginRight="8dp">

    <LinearLayout android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">
        <ImageView
            android:src="@android:drawable/ic_dialog_alert"
            android:layout_width="24dp"
            android:layout_height="24dp"/>
        <TextView
            android:text="气体报警"
            android:textStyle="bold"
            android:textColor="#222"
            android:textSize="16sp"
            android:layout_marginStart="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/tvAlarmStatus"
            android:text="新"
            android:textColor="#FF6666"
            android:background="#FFF0F0"
            android:layout_marginStart="8dp"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="12sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvAlarmContent"
        android:text="报警内容：CO超过上限值，已发出提醒报警"
        android:textColor="#333"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/tvAlarmLocation"
        android:text="报警地点：汽机凝汽器0米"
        android:textColor="#666"
        android:textSize="13sp"
        android:layout_marginTop="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/tvAlarmChannel"
        android:text="报警通道：通道1"
        android:textColor="#666"
        android:textSize="13sp"
        android:layout_marginTop="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/tvAlarmTime"
        android:text="今天 08:59:37-当前"
        android:textColor="#999"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:layout_gravity="end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout> 