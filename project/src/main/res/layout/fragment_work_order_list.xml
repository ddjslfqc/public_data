<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg">

    <LinearLayout
        android:id="@+id/top_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_ffffff"
        android:orientation="vertical"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/ll_search"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_wo_search"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_wo_search" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="搜索隐患名称、编号、处理人"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="#000000"
                android:textColorHint="#99898FA0"
                android:textSize="13sp" />

            <ImageView
                android:id="@+id/iv_mic"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_wo_mic" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/tab_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tab_all"
                    style="@style/WorkOrderFilterTab"
                    android:text="全部 12" />

                <TextView
                    android:id="@+id/tab_draft"
                    style="@style/WorkOrderFilterTab"
                    android:layout_marginStart="8dp"
                    android:text="待提交" />

                <TextView
                    android:id="@+id/tab_pending"
                    style="@style/WorkOrderFilterTab"
                    android:layout_marginStart="8dp"
                    android:text="待认领" />

                <TextView
                    android:id="@+id/tab_submitted"
                    style="@style/WorkOrderFilterTab"
                    android:layout_marginStart="8dp"
                    android:text="已提交"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tab_reject"
                    style="@style/WorkOrderFilterTab"
                    android:layout_marginStart="8dp"
                    android:text="驳回" />

                <TextView
                    android:id="@+id/tab_processing"
                    style="@style/WorkOrderFilterTab"
                    android:layout_marginStart="8dp"
                    android:text="处理中" />

                <TextView
                    android:id="@+id/tab_eval"
                    style="@style/WorkOrderFilterTab"
                    android:layout_marginStart="8dp"
                    android:text="待评价" />

                <TextView
                    android:id="@+id/tab_completed"
                    style="@style/WorkOrderFilterTab"
                    android:layout_marginStart="8dp"
                    android:text="已完成" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/stat_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/top_area">

        <LinearLayout
            android:id="@+id/stat_pending"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_wo_stat_pending"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/stat_pending_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/home_orange"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="待认领"
                android:textColor="#6D727E"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stat_processing"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:background="@drawable/bg_wo_stat_processing"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/stat_processing_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/home_indigo"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="处理中"
                android:textColor="#6D727E"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stat_eval"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="3dp"
            android:layout_weight="1"
            android:background="@drawable/bg_wo_stat_eval"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/stat_eval_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/home_purple"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="待评价"
                android:textColor="#6D727E"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stat_completed"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_wo_stat_completed"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/stat_completed_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/home_green"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="已完成"
                android:textColor="#6D727E"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stat_bar">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_work_orders"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="88dp" />

            <TextView
                android:id="@+id/tv_empty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="暂无工单"
                android:textColor="@color/home_text_normal"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_create"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="创建工单"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/home_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/color_ffffff" />

</androidx.constraintlayout.widget.ConstraintLayout>
