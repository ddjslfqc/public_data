<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- NoActionBar theme for ProjectActivity -->
    <style name="AppTheme.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- 透明对话框样式 -->
    <style name="TransparentDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="WorkOrderFilterTab">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">@dimen/wo_filter_tab_height</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">@dimen/wo_filter_tab_padding_h</item>
        <item name="android:paddingEnd">@dimen/wo_filter_tab_padding_h</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/home_text_normal</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">@null</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:clipToOutline">true</item>
    </style>

</resources>